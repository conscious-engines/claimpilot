# ClaimPilot — Environment Variables
# Copy this file to .env and fill in your keys

# OpenRouter API key (required for LLM features: chat, image analysis, insurer agent)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# LLM model to use (optional, defaults to anthropic/claude-sonnet-4)
# Other options: google/gemini-2.5-flash, openai/gpt-4o, meta-llama/llama-4-maverick
# LLM_MODEL=anthropic/claude-sonnet-4

# Database path (optional, defaults to data/claimpilot.db)
# CLAIMPILOT_DB=/path/to/custom.db
