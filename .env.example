# ClaimPilot POC — Environment Variables
# Copy this file to .env and fill in your keys

# fal.ai API key for Whisper transcription (voice notes)
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key-here

# Anthropic API key (optional — used if switching from claude CLI to direct API)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
